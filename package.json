{
  "name": "@emreunes/medusa-category-images",
  "version": "0.0.3",
  "description": "Medusa v2 plugin for managing product category images in Admin.",
  "author": "emreunes",
  "license": "MIT",
  "files": [
    ".medusa/server"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./*": "./.medusa/server/src/*.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    }
  },
  "keywords": [
    "medusa",
    "plugin",
    "medusa-plugin",
    "medusa-v2",
    "category-images",
    "product-category"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "prepublishOnly": "medusa plugin:build"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "2.16.0",
    "@medusajs/admin-shared": "2.16.0",
    "@medusajs/cli": "2.16.0",
    "@medusajs/framework": "2.16.0",
    "@medusajs/icons": "2.16.0",
    "@medusajs/js-sdk": "2.16.0",
    "@medusajs/medusa": "2.16.0",
    "@medusajs/test-utils": "2.16.0",
    "@medusajs/ui": "4.1.16",
    "@swc/core": "^1.15.41",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "yalc": "1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "2.16.0",
    "@medusajs/admin-shared": "2.16.0",
    "@medusajs/cli": "2.16.0",
    "@medusajs/framework": "2.16.0",
    "@medusajs/icons": "2.16.0",
    "@medusajs/js-sdk": "2.16.0",
    "@medusajs/medusa": "2.16.0",
    "@medusajs/test-utils": "2.16.0",
    "@medusajs/ui": "4.1.16"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.0.8"
}
